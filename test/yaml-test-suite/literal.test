<!-- test: Spec Example 8.17. Explicit Block Mapping Entries [5WE3] -->
<!-- in -->
? explicit key # Empty value
? |
  block key
: - one # Explicit compact
  - two # block value
<!-- json -->
{
  "explicit key": null,
  "block key\n": [
    "one",
    "two"
  ]
}

