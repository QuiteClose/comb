<!-- test: Literal scalars [4WA9] -->
<!-- in -->
- aaa: |2
    xxx
  bbb: |
    xxx
<!-- json -->
[
  {
    "aaa" : "xxx\n",
    "bbb" : "xxx\n"
  }
]

<!-- test: Spec Example 6.4. Line Prefixes [4ZYM] -->
<!-- in -->
plain: text
  lines
quoted: "text
  	lines"
block: |
  text
   	lines
<!-- json -->
{
  "plain": "text lines",
  "quoted": "text lines",
  "block": "text\n \tlines\n"
}

<!-- test: Spec Example 5.7. Block Scalar Indicators [5BVJ] -->
<!-- in -->
literal: |
  some
  text
folded: >
  some
  text
<!-- json -->
{
  "literal": "some\ntext\n",
  "folded": "some text\n"
}

