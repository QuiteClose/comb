<!-- test: Tags in Block Sequence [2AUY] -->
<!-- in -->
 - !!str a
 - b
 - !!int 42
 - d
<!-- json -->
[
  "a",
  "b",
  42,
  "d"
]

<!-- test: Three explicit integers in a block sequence [33X3] -->
<!-- in -->
---
- !!int 1
- !!int -2
- !!int 33
<!-- json -->
[
  1,
  -2,
  33
]

<!-- test: Explicit Non-Specific Tag [1.3] [52DL] -->
<!-- in -->
---
! a
<!-- json -->
"a"

<!-- test: Construct Binary [565N] -->
