<!-- test: Spec Example 8.22. Block Collection Nodes [57H4] -->
<!-- in -->
sequence: !!seq
- entry
- !!seq
 - nested
mapping: !!map
 foo: bar
<!-- json -->
{
  "sequence": [
    "entry",
    [
      "nested"
    ]
  ],
  "mapping": {
    "foo": "bar"
  }
}

<!-- test: Spec Example 6.21. Local Tag Prefix [5TYM] -->
<!-- in -->
%TAG !m! !my-
--- # Bulb here
!m!light fluorescent
...
%TAG !m! !my-
--- # Color here
!m!light green
<!-- json -->
"fluorescent"
"green"

<!-- test: Spec Example 6.26. Tag Shorthands [6CK3] -->
<!-- in -->
%TAG !e! tag:example.com,2000:app/
---
- !local foo
- !!str bar
- !e!tag%21 baz
<!-- json -->
[
  "foo",
  "bar",
  "baz"
]

<!-- test: Tags for Block Objects [6JWB] -->
<!-- in -->
foo: !!seq
  - !!str a
  - !!map
    key: !!str value
<!-- json -->
{
  "foo": [
    "a",
    {
      "key": "value"
    }
  ]
}

<!-- test: Spec Example 6.18. Primary Tag Handle [1.3] [6WLZ] -->
<!-- in -->
# Private
---
!foo "bar"
...
# Global
%TAG ! tag:example.com,2000:app/
---
!foo "bar"
<!-- json -->
"bar"
"bar"

<!-- test: Tags in Implicit Mapping [74H7] -->
<!-- in -->
!!str a: b
c: !!int 42
e: !!str f
g: h
!!str 23: !!bool false
<!-- json -->
{
  "a": "b",
  "c": 42,
  "e": "f",
  "g": "h",
  "23": false
}

<!-- test: Spec Example 6.24. Verbatim Tags [7FWL] -->
<!-- in -->
!<tag:yaml.org,2002:str> foo :
  !<!bar> baz
<!-- json -->
{
  "foo": "baz"
}

<!-- test: Explicit Non-Specific Tag [8MK2] -->
<!-- in -->
! a
<!-- json -->
"a"

<!-- test: Need document footer before directives [9HCY] -->
<!-- error -->
<!-- in -->
!foo "bar"
%TAG ! tag:example.com,2000:app/
---
!foo "bar"

<!-- test: Spec Example 6.18. Primary Tag Handle [9WXW] -->
<!-- in -->
# Private
!foo "bar"
...
# Global
%TAG ! tag:example.com,2000:app/
---
!foo "bar"
<!-- json -->
"bar"
"bar"

<!-- test: Spec Example 6.20. Tag Handles [CC74] -->
<!-- in -->
%TAG !e! tag:example.com,2000:app/
---
!e!foo "bar"
<!-- json -->
"bar"

<!-- test: Tags for Flow Objects [EHF6] -->
<!-- in -->
!!map {
  k: !!seq
  [ a, !!str b]
}
<!-- json -->
{
  "k": [
    "a",
    "b"
  ]
}

<!-- test: Spec Example 2.26. Ordered Mappings [J7PZ] -->
<!-- in -->
# The !!omap tag is one of the optional types
# introduced for YAML 1.1. In 1.2, it is not
# part of the standard tags and should not be
# enabled by default.
# Ordered maps are represented as
# A sequence of mappings, with
# each mapping having one key
--- !!omap
- Mark McGwire: 65
- Sammy Sosa: 63
- Ken Griffy: 58
<!-- json -->
[
  {
    "Mark McGwire": 65
  },
  {
    "Sammy Sosa": 63
  },
  {
    "Ken Griffy": 58
  }
]

<!-- test: Invalid tag [LHL4] -->
<!-- error -->
<!-- in -->
---
!invalid{}tag scalar

<!-- test: Spec Example 6.19. Secondary Tag Handle [P76L] -->
<!-- in -->
%TAG !! tag:example.com,2000:app/
---
!!int 1 - 3 # Interval, not integer
<!-- json -->
"1 - 3"

<!-- test: Tag shorthand used in documents but only defined in the first [QLJ7] -->
<!-- error -->
<!-- in -->
%TAG !prefix! tag:example.com,2011:
--- !prefix!A
a: b
--- !prefix!B
c: d
--- !prefix!C
e: f

<!-- test: Spec Example 6.28. Non-Specific Tags [S4JQ] -->
<!-- in -->
# Assuming conventional resolution:
- "12"
- 12
- ! 12
<!-- json -->
[
  "12",
  12,
  "12"
]

<!-- test: Spec Example 6.16. “TAG” directive [U3C3] -->
<!-- in -->
%TAG !yaml! tag:yaml.org,2002:
---
!yaml!str "foo"
<!-- json -->
"foo"

<!-- test: Invalid comma in tag [U99R] -->
<!-- error -->
<!-- in -->
- !!str, xxx

<!-- test: Spec Example 6.22. Global Tag Prefix [Z9M4] -->
<!-- in -->
%TAG !e! tag:example.com,2000:app/
---
- !e!foo "bar"
<!-- json -->
[
  "bar"
]
