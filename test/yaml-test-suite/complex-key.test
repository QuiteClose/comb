<!-- in -->
: a
: b

<!-- test: Spec Example 2.25. Unordered Sets [2XXW] -->
<!-- in -->
# Sets are represented as a
# Mapping where each key is
# associated with a null value
--- !!set
? Mark McGwire
? Sammy Sosa
? Ken Griff
<!-- json -->
{
  "Mark McGwire": null,
  "Sammy Sosa": null,
  "Ken Griff": null
}

<!-- test: Tags for Root Objects [35KP] -->
<!-- in -->
--- !!map
? a
: b
--- !!seq
- !!str c
--- !!str
d
e
<!-- json -->
{
  "a": "b"
}
[
  "c"
]
"d e"

