<!-- test: Invalid Mapping in plain scalar [HU3P] -->
<!-- error -->
<!-- in -->
key:
  word1 word2
  no: key

<!-- test: Question marks in scalars [JR7V] -->
<!-- in -->
- a?string
- another ? string
- key: value?
- [a?string]
- [another ? string]
- {key: value? }
- {key: value?}
- {key?: value }
<!-- json -->
[
  "a?string",
  "another ? string",
  {
    "key": "value?"
  },
  [
    "a?string"
  ],
  [
    "another ? string"
  ],
  {
    "key": "value?"
  },
  {
    "key": "value?"
  },
  {
    "key?": "value"
  }
]

<!-- test: Block Mapping with Multiline Scalars [JTV5] -->
<!-- in -->
? a
  true
: null
  d
? e
  42
<!-- json -->
{
  "a true": "null d",
  "e 42": null
}

<!-- test: Scalars on --- line [KSS4] -->
<!-- in -->
--- "quoted
string"
--- &node foo
<!-- json -->
"quoted string"
"foo"

<!-- test: Whitespace After Scalars in Flow [LP6E] -->
<!-- in -->
- [a, b , c ]
- { "a"  : b
   , c : 'd' ,
   e   : "f"
  }
- [      ]
<!-- json -->
[
  [
    "a",
    "b",
    "c"
  ],
  {
    "a": "b",
    "c": "d",
    "e": "f"
  },
  []
]

