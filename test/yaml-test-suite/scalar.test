  "single multiline - sequence entry"
]

<!-- test: Trailing comment in multiline plain scalar [BF9H] -->
<!-- error -->
<!-- in -->
---
plain: a
       b # end of scalar
       c

<!-- test: Comment between plain scalar lines [BS4K] -->
<!-- error -->
<!-- in -->
word1  # comment
word2

<!-- test: Spec Example 7.10. Plain Characters [DBG4] -->
<!-- in -->
# Outside flow collection:
- ::vector
- ": - ()"
- Up, up, and away!
- -123
- http://example.com/foo#bar
# Inside flow collection:
- [ ::vector,
  ": - ()",
  "Up, up and away!",
  -123,
  http://example.com/foo#bar ]
<!-- json -->
[
  "::vector",
  ": - ()",
  "Up, up, and away!",
  -123,
  "http://example.com/foo#bar",
  [
    "::vector",
    ": - ()",
    "Up, up and away!",
    -123,
    "http://example.com/foo#bar"
  ]
]

