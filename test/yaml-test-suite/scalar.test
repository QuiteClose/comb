<!-- in -->
---
a
b  
  c
d

e
<!-- json -->
"a b c d\ne"

<!-- test: Three dashes and content without space [1.3] [EXG3] -->
<!-- in -->
---
---word1
word2
<!-- json -->
"---word1 word2"

<!-- test: Allowed characters in plain scalars [FBC9] -->
<!-- in -->
safe: a!"#$%&'()*+,-./09:;<=>?@AZ[\]^_`az{|}~
     !"#$%&'()*+,-./09:;<=>?@AZ[\]^_`az{|}~
safe question mark: ?foo
safe colon: :foo
safe dash: -foo
<!-- json -->
{
  "safe": "a!\"#$%&'()*+,-./09:;<=>?@AZ[\\]^_`az{|}~ !\"#$%&'()*+,-./09:;<=>?@AZ[\\]^_`az{|}~",
  "safe question mark": "?foo",
  "safe colon": ":foo",
  "safe dash": "-foo"
}

<!-- test: Tags on Empty Scalars [FH7J] -->
<!-- in -->
- !!str
-
  !!null : a
  b: !!str
- !!str : !!null

<!-- test: Spec Example 2.17. Quoted Scalars [G4RS] -->
<!-- in -->
unicode: "Sosa did fine.\u263A"
control: "\b1998\t1999\t2000\n"
hex esc: "\x0d\x0a is \r\n"

single: '"Howdy!" he cried.'
quoted: ' # Not a ''comment''.'
tie-fighter: '|\-*-/|'
<!-- json -->
{
  "unicode": "Sosa did fine.☺",
  "control": "\b1998\t1999\t2000\n",
  "hex esc": "\r\n is \r\n",
  "single": "\"Howdy!\" he cried.",
  "quoted": " # Not a 'comment'.",
  "tie-fighter": "|\\-*-/|"
}

