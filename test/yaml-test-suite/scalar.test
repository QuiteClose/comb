<!-- test: Allowed characters in keys [2EBW] -->
<!-- in -->
a!"#$%&'()*+,-./09:;<=>?@AZ[\]^_`az{|}~: safe
?foo: safe question mark
:foo: safe colon
-foo: safe dash
this is#not: a comment
<!-- json -->
{
  "a!\"#$%&'()*+,-./09:;<=>?@AZ[\\]^_`az{|}~": "safe",
  "?foo": "safe question mark",
  ":foo": "safe colon",
  "-foo": "safe dash",
  "this is#not": "a comment"
}

<!-- test: Multiline plain scalar with empty line [36F6] -->
<!-- in -->
---
plain: a
 b

 c
<!-- json -->
{
  "plain": "a b\nc"
}

<!-- test: Plain Scalar looking like key, comment, anchor and tag [3MYT] -->
<!-- in -->
---
k:#foo
 &a !t s
<!-- json -->
"k:#foo &a !t s"

<!-- test: Spec Example 2.18. Multi-line Flow Scalars [4CQQ] -->
<!-- in -->
plain:
  This unquoted scalar
  spans many lines.

quoted: "So does this
  quoted scalar.\n"
<!-- json -->
{
  "plain": "This unquoted scalar spans many lines.",
  "quoted": "So does this quoted scalar.\n"
}

<!-- test: Spec Example 7.7. Single Quoted Characters [4GC6] -->
<!-- in -->
'here''s to "quotes"'
<!-- json -->
"here's to \"quotes\""

<!-- test: Colon in Double Quoted String [4UYU] -->
<!-- in -->
"foo: bar\": baz"
<!-- json -->
"foo: bar\": baz"

<!-- test: Plain scalar with backslashes [4V8U] -->
<!-- in -->
---
plain\value\with\backslashes
<!-- json -->
"plain\\value\\with\\backslashes"

<!-- test: Colon at the beginning of adjacent flow scalar [5T43] -->
<!-- in -->
- { "key":value }
- { "key"::value }
<!-- json -->
[
  {
    "key": "value"
  },
  {
    "key": ":value"
  }
]

<!-- test: Spec Example 7.6. Double Quoted Lines [7A4E] -->
<!-- in -->
" 1st non-empty

 2nd non-empty 
	3rd non-empty "
<!-- json -->
" 1st non-empty\n2nd non-empty 3rd non-empty "

<!-- test: Three dashes and content without space [82AN] -->
<!-- in -->
---word1
word2
<!-- json -->
"---word1 word2"

<!-- test: Plain mapping key ending with colon [8CWC] -->
<!-- in -->
---
key ends with two colons::: value
<!-- json -->
{
  "key ends with two colons::": "value"
}

