  1,
  2,
  3
]

<!-- test: Flow Mapping [54T7] -->
<!-- in -->
{foo: you, bar: far}
<!-- json -->
{
  "foo": "you",
  "bar": "far"
}

<!-- test: Flow mapping edge cases [58MP] -->
<!-- in -->
{x: :x}
<!-- json -->
{
  "x": ":x"
}

<!-- test: Spec Example 7.15. Flow Mappings [5C5M] -->
<!-- in -->
- { one : two , three: four , }
- {five: six,seven : eight}
<!-- json -->
[
  {
    "one": "two",
    "three": "four"
  },
  {
    "five": "six",
    "seven": "eight"
  }
]

<!-- test: Spec Example 7.13. Flow Sequence [5KJE] -->
<!-- in -->
- [ one, two, ]
- [three ,four]
<!-- json -->
[
  [
    "one",
    "two"
  ],
  [
    "three",
    "four"
  ]
]

<!-- test: Invalid block mapping key on same line as previous key [62EZ] -->
<!-- error -->
<!-- in -->
---
x: { y: z }in: valid

<!-- test: Question mark at start of flow key [652Z] -->
<!-- in -->
{ ?foo: bar,
bar: 42
}
<!-- json -->
{
  "?foo" : "bar",
  "bar" : 42
}

<!-- test: Spec Example 6.1. Indentation Spaces [6HB6] -->
<!-- in -->
  # Leading comment line spaces are
   # neither content nor indentation.
    
Not indented:
 By one space: |
    By four
      spaces
 Flow style: [    # Leading spaces
   By two,        # in flow style
  Also by two,    # are neither
  	Still by two   # content nor
    ]             # indentation.
<!-- json -->
{
  "Not indented": {
    "By one space": "By four\n  spaces\n",
    "Flow style": [
      "By two",
      "Also by two",
      "Still by two"
    ]
  }
}

<!-- test: Flow sequence without closing bracket [6JTT] -->
<!-- error -->
<!-- in -->
---
[ [ a, b, c ]

<!-- test: Comment in flow sequence before comma [7TMG] -->
<!-- in -->
---
[ word1
# comment
, word2]
<!-- json -->
[
  "word1",
  "word2"
]

<!-- test: Empty flow collections [7ZZ5] -->
<!-- in -->
---
nested sequences:
- - - []
- - - {}
key1: []
key2: {}
<!-- json -->
{
  "nested sequences": [
    [
      [
        []
      ]
    ],
    [
      [
        {}
      ]
    ]
  ],
  "key1": [],
  "key2": {}
}

<!-- test: Spec Example 7.8. Single Quoted Implicit Keys [87E4] -->
<!-- in -->
'implicit block key' : [
  'implicit flow key' : value,
 ]
<!-- json -->
{
  "implicit block key": [
    {
      "implicit flow key": "value"
    }
  ]
}

<!-- test: Multiline plain flow mapping key without value [8KB6] -->
<!-- in -->
---
- { single line, a: b}
- { multi
  line, a: b}
<!-- json -->
[
  {
    "single line": null,
    "a": "b"
  },
  {
    "multi line": null,
    "a": "b"
  }
]

<!-- test: Spec Example 7.14. Flow Sequence Entries [8UDB] -->
<!-- in -->
[
"double
 quoted", 'single
           quoted',
plain
 text, [ nested ],
single: pair,
]
<!-- json -->
[
  "double quoted",
  "single quoted",
  "plain text",
  [
    "nested"
  ],
  {
    "single": "pair"
  }
]

