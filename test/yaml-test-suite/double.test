  "foo: bar\\": "baz'"
}

<!-- test: Spec Example 6.13. Reserved Directives [6LVF] -->
<!-- in -->
%FOO  bar baz # Should be ignored
              # with a warning.
--- "foo"
<!-- json -->
"foo"

<!-- test: Allowed characters in quoted mapping key [6SLA] -->
<!-- in -->
"foo\nbar:baz\tx \\$%^&*()x": 23
'x\ny:z\tx $%^&*()x': 24
<!-- json -->
{
  "foo\nbar:baz\tx \\$%^&*()x": 23,
  "x\\ny:z\\tx $%^&*()x": 24
}

<!-- test: Spec Example 6.8. Flow Folding [1.3] [6WPF] -->
<!-- in -->
---
"
  foo 
 
    bar

  baz
"
<!-- json -->
" foo\nbar\nbaz "

