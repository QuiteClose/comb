  "First occurrence": "Value",
  "Second occurrence": "Value"
}

<!-- test: Spec Example 7.24. Flow Nodes [LE5A] -->
<!-- in -->
- !!str "a"
- 'b'
- &anchor "c"
- *anchor
- !!str
<!-- json -->
[
  "a",
  "b",
  "c",
  "c",
  ""
]

